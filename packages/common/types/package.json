      "require": "./dist/field.cjs",
      "import": "./dist/field.mjs"
    },
    "./file": {
      "types": "./dist/file.d.ts",
      "require": "./dist/file.cjs",
      "import": "./dist/file.mjs"
    },
    "./filter": {
      "types": "./dist/filter.d.ts",
      "require": "./dist/filter.cjs",
      "import": "./dist/filter.mjs"
    },
    "./flow": {
      "types": "./dist/flow.d.ts",
