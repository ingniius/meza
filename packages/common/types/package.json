{
  "name": "@azem/types",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ingniius/meza.git",
    "directory": "packages/common/types"
  },
  "license": "Apache-2.0",
  "author": "@ingniius <ingniius@pm.me>",
