    "./notification": {
      "types": "./dist/notification.d.ts",
      "require": "./dist/notification.cjs",
      "import": "./dist/notification.mjs"
    },
    "./overview": {
      "types": "./dist/overview.d.ts",
      "require": "./dist/overview.cjs",
      "import": "./dist/overview.mjs"
