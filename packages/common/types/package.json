    "./relation": {
      "types": "./dist/relation.d.ts",
      "require": "./dist/relation.cjs",
      "import": "./dist/relation.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "require": "./dist/schema.cjs",
      "import": "./dist/schema.mjs"
    },
    "./setting": {
      "types": "./dist/setting.d.ts",
      "require": "./dist/setting.cjs",
