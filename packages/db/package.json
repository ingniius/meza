{
  "name": "@azem/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./generated/client/*": "./generated/client/*",
    "./generated/schemas/*": "./generated/schemas/*",
    "./keys": "./keys.ts",
    ".": "./index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "[ ! -d generated ] && run-s analyze || true",
    "analyze": "dotenv-run -- prisma generate --no-hints --schema=./prisma/schema",
    "build": "dotenv-run -- prisma generate --no-hints --schema=./prisma/schema",
    "lint": "eslint . --fix --cache --cache-location .cache/.eslintcache",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo node_modules"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^6.17.1",
    "@prisma/client": "^6.17.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "server-only": "^0.0.1",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "prisma": "6.17.1",
    "prisma-zod-generator": "^1.28.3"
  }
}
