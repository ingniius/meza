    "@azem/typescript": "workspace:*",
    "@nuxt/devtools": "^1.6.1",
    "@nuxt/eslint": "^0.7.1",
    "@nuxt/test-utils": "^3.14.4",
    "nuxt": "^3.14.1592",
    "vue": "^3.5.13"
  },
  "prettier": "@azem/prettier/base",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
