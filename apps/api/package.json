    "@azem/tokens": "workspace:*",
    "@azem/types": "workspace:*",
    "@azem/utils": "workspace:*",
    "@azem/validators": "workspace:*",
    "axios": "^1.7.8",
    "express": "^4.21.1",
    "geojson": "^0.5.0",
    "knex": "^3.1.0",
    "ms": "^2.1.3",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/geojson": "^7946.0.14",
    "@types/ms": "^0.7.34"
